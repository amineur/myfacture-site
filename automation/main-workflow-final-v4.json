      {
        "parameters": {
          "jsCode": "// On parcourt tous les binaires pour trouver le PDF qui ressemble à une facture\nconst bin = $binary || {};\nlet invoiceKey = null;\n\nfor (const key of Object.keys(bin)) {\n    const file = bin[key];\n    const name = (file.fileName || '').toLowerCase();\n    if (name.endsWith('.pdf') && (name.includes('facture') || name.includes('invoice') || name.includes('vtconsult'))) {\n        invoiceKey = key;\n        break;\n    }\n}\n\nif (!invoiceKey) {\n    for (const key of Object.keys(bin)) {\n        if ((bin[key].fileName || '').toLowerCase().endsWith('.pdf')) {\n            invoiceKey = key;\n            break;\n        }\n    }\n}\n\nif (invoiceKey) {\n    return { \n        json: { ...$json, _invoiceKey: invoiceKey },\n        binary: { invoice_pdf: bin[invoiceKey] }\n    };\n}\n\nreturn [];"
        },
        "id": "filter-invoice",
        "name": "Isoler la Facture PDF",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          464,
          304
        ]
      },
