        "parameters": {
          "prompt": "=Tu es un assistant comptable. Analyse cet email pour extraire les informations de facturation.\n\nSujet : {{$json[\"subject\"]}}\nContenu : {{$json[\"snippet\"]}}\nExpéditeur : {{$json[\"from\"]}}\n\n------- \n\nSORTIE JSON STRICTE :\n\n{\n  \"supplier_name\": \"...\",\n  \"amount_ttc\": 0.00,\n  \"amount_ht\": 0.00,\n  \"reference\": \"...\",\n  \"issued_date\": \"YYYY-MM-DD\",\n  \"due_date\": \"YYYY-MM-DD\"\n}",
          "options": {},
