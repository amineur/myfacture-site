        "parameters": {
          "jsCode": "// Nettoyage du JSON renvoyé par OpenAI\nlet content = $node[\"Extraire Données (OpenAI)\"].json[\"message\"][\"content\"];\ncontent = content.replace(/```json/g, '').replace(/```/g, '').trim();\n\ntry {\n    const data = JSON.parse(content);\n    return {\n        json: {\n            ...data,\n            company_handle: \"@urban.hit\",\n            pdf_base64: $node[\"Isoler la Facture PDF\"].binary.invoice_pdf.data\n        }\n    };\n} catch (e) {\n    throw new Error(\"Erreur de parsing JSON OpenAI: \" + e.message + \" | Content: \" + content);\n}"
