# ─── Database (PostgreSQL sur core_net) ────────────────────────────────────────
# "postgres" = nom du service Docker PostgreSQL sur core_net
DATABASE_URL=postgresql://dashboard_user:CHANGE_THIS_PASSWORD@postgres:5432/dashboard_media

# ─── NextAuth ──────────────────────────────────────────────────────────────────
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET=GENERER_AVEC_openssl_rand_-base64_32
NEXTAUTH_URL=https://dashboard.urban-hit.fr

# ─── Webhook automation email → facture ───────────────────────────────────────
AUTOMATION_API_KEY=votre_cle_secrete_ici

# ─── Qonto OAuth ──────────────────────────────────────────────────────────────
QONTO_CLIENT_ID=votre_qonto_client_id
QONTO_CLIENT_SECRET=votre_qonto_client_secret
QONTO_REDIRECT_URI=https://dashboard.urban-hit.fr/api/qonto/callback

# ─── OpenAI (assistant IA) ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── SMTP OVH (envoi emails de paiement) ─────────────────────────────────────
SMTP_USER=noreply@urbanhit.fr
SMTP_PASSWORD=votre_mot_de_passe_smtp_ovh

# ─── NODE_ENV (set automatically by Docker) ───────────────────────────────────
# NODE_ENV=production
